diff --git a/src/include/palclock.h b/src/include/palclock.h
new file mode 100644
index 000000000..52df5b6b1
--- /dev/null
+++ b/src/include/palclock.h
@@ -0,0 +1,19 @@
+#ifndef __PALCLOCK_H_
+#define __PALCLOCK_H_
+
+#include <stdint.h>
+#include <sys/time.h>
+#include <time.h>
+
+typedef enum palclock_origin_e {
+    PALCLOCK_ORIGIN_LIBC = 0,
+    PALCLOCK_ORIGIN_LIBC_SYSCALL = 1,
+    PALCLOCK_ORIGIN_INSTRUCTION_SYSCALL = 2,
+} palclock_origin_t;
+
+int palclock_enabled(void);
+int palclock_clock_gettime(palclock_origin_t origin, clockid_t clock_id, struct timespec* value);
+int palclock_gettimeofday(palclock_origin_t origin, struct timeval* value, void* timezone_value);
+time_t palclock_time(palclock_origin_t origin, time_t* result);
+
+#endif
diff --git a/src/tools/palclock.c b/src/tools/palclock.c
new file mode 100644
index 000000000..9aa0d0191
--- /dev/null
+++ b/src/tools/palclock.c
@@ -0,0 +1,216 @@
+#define _GNU_SOURCE
+
+#include <errno.h>
+#include <sched.h>
+#include <stdatomic.h>
+#include <stdint.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/time.h>
+#include <time.h>
+
+#include "debug.h"
+#include "palclock.h"
+#include "x64emu.h"
+
+#define NS_PER_SECOND 1000000000LL
+
+static _Atomic int init_state = 0;
+static _Thread_local int64_t thread_last_realtime_ns = 0;
+static _Atomic unsigned int trace_mask = 0;
+static int enabled = 0;
+static int64_t anchor_epoch_ns = 0;
+static int64_t anchor_monotonic_ns = 0;
+
+static int64_t timespec_to_ns(const struct timespec* value)
+{
+    return (int64_t)value->tv_sec * NS_PER_SECOND + value->tv_nsec;
+}
+
+static void ns_to_timespec(int64_t value, struct timespec* result)
+{
+    result->tv_sec = (time_t)(value / NS_PER_SECOND);
+    result->tv_nsec = (long)(value % NS_PER_SECOND);
+    if(result->tv_nsec < 0) {
+        result->tv_sec -= 1;
+        result->tv_nsec += NS_PER_SECOND;
+    }
+}
+
+static int parse_ns(const char* name, int64_t* result)
+{
+    const char* value = getenv(name);
+    char* end = NULL;
+    long long parsed;
+
+    if(value == NULL || *value == '\0')
+        return -1;
+
+    errno = 0;
+    parsed = strtoll(value, &end, 10);
+    if(errno != 0 || end == value || *end != '\0' || parsed <= 0)
+        return -1;
+
+    *result = (int64_t)parsed;
+    return 0;
+}
+
+static void initialize_clock(void)
+{
+    int expected = 0;
+    const char* setting;
+    struct timespec realtime;
+    struct timespec monotonic;
+
+    if(!atomic_compare_exchange_strong_explicit(
+            &init_state, &expected, 1, memory_order_acq_rel, memory_order_acquire)) {
+        while(atomic_load_explicit(&init_state, memory_order_acquire) != 2)
+            sched_yield();
+        return;
+    }
+
+    setting = getenv("BOX64_PAL_CLOCK");
+    enabled = setting != NULL && strcmp(setting, "0") != 0 && *setting != '\0';
+    if(!enabled) {
+        atomic_store_explicit(&init_state, 2, memory_order_release);
+        return;
+    }
+
+    if(parse_ns("PAL_CLOCK_ANCHOR_EPOCH_NS", &anchor_epoch_ns) == 0
+        && parse_ns("PAL_CLOCK_ANCHOR_MONOTONIC_NS", &anchor_monotonic_ns) == 0) {
+        printf_log(LOG_NONE,
+            "[box64-pal-clock] active: external epoch anchor + CLOCK_MONOTONIC_RAW\n");
+    } else {
+        if(clock_gettime(CLOCK_REALTIME, &realtime) != 0
+            || clock_gettime(CLOCK_MONOTONIC_RAW, &monotonic) != 0) {
+            printf_log(LOG_NONE, "[box64-pal-clock] fatal: unable to initialize clock anchor\n");
+            enabled = 0;
+            atomic_store_explicit(&init_state, 2, memory_order_release);
+            return;
+        }
+        anchor_epoch_ns = timespec_to_ns(&realtime);
+        anchor_monotonic_ns = timespec_to_ns(&monotonic);
+        printf_log(LOG_NONE,
+            "[box64-pal-clock] warning: external anchor missing; process-start system time used\n");
+    }
+
+    thread_last_realtime_ns = 0;
+    atomic_store_explicit(&init_state, 2, memory_order_release);
+}
+
+int palclock_enabled(void)
+{
+    initialize_clock();
+    return enabled;
+}
+
+static void trace_origin_once(palclock_origin_t origin)
+{
+    unsigned int bit = 1U << (unsigned int)origin;
+    unsigned int previous = atomic_fetch_or_explicit(&trace_mask, bit, memory_order_relaxed);
+
+    if((previous & bit) != 0)
+        return;
+    switch(origin) {
+        case PALCLOCK_ORIGIN_LIBC:
+            printf_log(LOG_NONE, "[box64-pal-clock] libc/librt wrapper path active\n");
+            break;
+        case PALCLOCK_ORIGIN_LIBC_SYSCALL:
+            printf_log(LOG_NONE, "[box64-pal-clock] libc syscall() path active\n");
+            break;
+        case PALCLOCK_ORIGIN_INSTRUCTION_SYSCALL:
+            printf_log(LOG_NONE, "[box64-pal-clock] x86 syscall instruction path active\n");
+            break;
+    }
+}
+
+static int64_t virtual_realtime_ns(void)
+{
+    struct timespec monotonic;
+    int64_t candidate;
+    int64_t previous;
+
+    if(clock_gettime(CLOCK_MONOTONIC_RAW, &monotonic) != 0) {
+        previous = thread_last_realtime_ns;
+        candidate = previous > 0 ? previous + 1 : anchor_epoch_ns;
+        thread_last_realtime_ns = candidate;
+        return candidate;
+    }
+
+    candidate = anchor_epoch_ns + timespec_to_ns(&monotonic) - anchor_monotonic_ns;
+    previous = thread_last_realtime_ns;
+    if(candidate <= previous) {
+        candidate = previous + 1;
+    }
+
+    thread_last_realtime_ns = candidate;
+    return candidate;
+}
+
+int palclock_clock_gettime(
+    palclock_origin_t origin, clockid_t clock_id, struct timespec* value)
+{
+    if(!palclock_enabled()
+        || (clock_id != CLOCK_REALTIME
+#ifdef CLOCK_REALTIME_COARSE
+            && clock_id != CLOCK_REALTIME_COARSE
+#endif
+        ))
+        return clock_gettime(clock_id, value);
+
+    trace_origin_once(origin);
+    ns_to_timespec(virtual_realtime_ns(), value);
+    return 0;
+}
+
+int palclock_gettimeofday(
+    palclock_origin_t origin, struct timeval* value, void* timezone_value)
+{
+    int64_t virtual_ns;
+
+    if(!palclock_enabled())
+        return gettimeofday(value, timezone_value);
+
+    trace_origin_once(origin);
+    if(timezone_value != NULL)
+        memset(timezone_value, 0, sizeof(struct timezone));
+    virtual_ns = virtual_realtime_ns();
+    value->tv_sec = (time_t)(virtual_ns / NS_PER_SECOND);
+    value->tv_usec = (suseconds_t)((virtual_ns % NS_PER_SECOND) / 1000);
+    return 0;
+}
+
+time_t palclock_time(palclock_origin_t origin, time_t* result)
+{
+    time_t value;
+
+    if(!palclock_enabled())
+        return time(result);
+
+    trace_origin_once(origin);
+    value = (time_t)(virtual_realtime_ns() / NS_PER_SECOND);
+    if(result != NULL)
+        *result = value;
+    return value;
+}
+
+EXPORT int my_clock_gettime(x64emu_t* emu, int clock_id, struct timespec* value)
+{
+    (void)emu;
+    return palclock_clock_gettime(PALCLOCK_ORIGIN_LIBC, (clockid_t)clock_id, value);
+}
+
+EXPORT int my_gettimeofday(x64emu_t* emu, struct timeval* value, void* timezone_value)
+{
+    (void)emu;
+    return palclock_gettimeofday(PALCLOCK_ORIGIN_LIBC, value, timezone_value);
+}
+
+EXPORT int my___gettimeofday(x64emu_t* emu, struct timeval* value, void* timezone_value)
+    __attribute__((alias("my_gettimeofday")));
+
+EXPORT time_t my_time(x64emu_t* emu, time_t* result)
+{
+    (void)emu;
+    return palclock_time(PALCLOCK_ORIGIN_LIBC, result);
+}
